# =============================================================================
# Elliott Wave Engine — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------------
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram group/channel chat ID (negative number for groups)
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Thread/topic IDs for routing alerts to specific topics
TELEGRAM_TOPIC_ID=0
TOPIC_NORMAL_ID=0
TOPIC_VIP_ID=0
TOPIC_CHAT_ID=0
TOPIC_15M_ID=0
TOPIC_MEMBER_ID=0

# Message header/footer (optional branding text)
TELEGRAM_MESSAGE_HEADER=📊 BTCUSDT Elliott Wave Alert
TELEGRAM_MESSAGE_FOOTER=

# Thai label overrides (optional)
TELEGRAM_MESSAGE_SUPPORT=แนวรับ
TELEGRAM_MESSAGE_RESISTANCE=แนวต้าน
TELEGRAM_MESSAGE_SCENARIO=สถานการณ์
TELEGRAM_ALERT_LEVEL=⚠️ ราคาเข้าใกล้ระดับสำคัญ
TELEGRAM_ALERT_BREAK=🚨 ราคา Break Level

# Daily watch reminder (07:05–07:59 Asia/Bangkok, once per day) — uses TELEGRAM_TOPIC_ID if set
# DAILY_WATCH_TOPIC_ID=590
# DAILY_WATCH_START_HOUR=7
# DAILY_WATCH_START_MINUTE=5
# DAILY_WATCH_END_HOUR=7
# DAILY_WATCH_END_MINUTE=59

# -----------------------------------------------------------------------------
# VPS (optional — for reference only, do NOT use password auth in production)
# Use SSH key-based authentication instead of passwords
# -----------------------------------------------------------------------------
VPS_HOST=your.vps.ip.address
VPS_USER=your_vps_user
# VPS_PASSWORD=  <-- Remove this; use SSH keys instead

# -----------------------------------------------------------------------------
# Google Sheets (optional)
# -----------------------------------------------------------------------------
# Set to true to enable Google Sheets sync
GOOGLE_SHEETS_ENABLED=false

# Google Sheets document ID (from the URL)
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Path to Google service account credentials JSON
# Download from Google Cloud Console → IAM → Service Accounts
GOOGLE_CREDENTIALS_PATH=storage/credentials.json

# Worksheet tab names
GOOGLE_SHEETS_TAB=wave_log
GOOGLE_SHEETS_SIGNALS_TAB=signals
GOOGLE_SHEETS_EVENTS_TAB=signal_events
GOOGLE_SHEETS_DAILY_TAB=daily_summary

# Default monitored pairs for orchestrator, dashboard, sync, and backtests.
MONITOR_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,DOGEUSDT,XRPUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,LTCUSDT

# -----------------------------------------------------------------------------
# Binance Futures Execution (Testnet-safe defaults)
# -----------------------------------------------------------------------------
# Global kill switch for ALL exchange orders. When set to 1/true/yes/on,
# the execution layer must not send any orders to Binance (including testnet).
KILL_SWITCH=0

# Enable/disable Binance execution logic in the app.
BINANCE_EXECUTION_ENABLED=false

# Allow live order placement. Keep this false until you are ready.
BINANCE_LIVE_ORDER_ENABLED=false

# Use Binance Futures testnet by default for safety.
BINANCE_USE_TESTNET=true

# API credentials (never commit real keys).
BINANCE_FUTURES_API_KEY=your_testnet_api_key_here
BINANCE_FUTURES_API_SECRET=your_testnet_api_secret_here

# Risk and sizing
BINANCE_RISK_PER_TRADE=0.01
BINANCE_DEFAULT_LEVERAGE=1
BINANCE_MARGIN_TYPE=ISOLATED

# TP allocation splits – will be normalized to sum to 1.0 if misconfigured.
BINANCE_TP1_SIZE_PCT=0.4
BINANCE_TP2_SIZE_PCT=0.3
BINANCE_TP3_SIZE_PCT=0.3
# % from entry when DB/exchange has no SL (reconcile / ensure_protection)
RECOVERY_EMERGENCY_SL_PCT=5

# -----------------------------------------------------------------------------
# Database (optional — defaults to storage/wave_engine.db)
# -----------------------------------------------------------------------------
# WAVE_DB_PATH=storage/wave_engine.db
